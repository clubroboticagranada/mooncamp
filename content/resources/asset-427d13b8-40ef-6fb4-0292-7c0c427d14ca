<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ROBOT CONTROL · MQTT</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mqtt/5.3.4/mqtt.min.js"></script>
<style>
  :root {
    --bg: #080c10;
    --panel: #0d1218;
    --panel2: #111820;
    --border: #1e2e3e;
    --border2: #1a3a50;
    --accent: #00c8ff;
    --accent2: #0af;
    --accent-dim: rgba(0,200,255,.12);
    --accent-glow: rgba(0,200,255,.35);
    --red: #ff3c5a;
    --red-dim: rgba(255,60,90,.15);
    --green: #00ff9d;
    --green-dim: rgba(0,255,157,.12);
    --amber: #ffb830;
    --amber-dim: rgba(255,184,48,.12);
    --text: #c8dce8;
    --text2: #5a7a8a;
    --text3: #3a5060;
    --mono: 'Share Tech Mono', monospace;
    --head: 'Rajdhani', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--head);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  /* Scanline overlay */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.03) 2px, rgba(0,0,0,.03) 4px);
    pointer-events: none; z-index: 1000;
  }

  /* Grid background */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background-image: linear-gradient(rgba(0,200,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,200,255,.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none; z-index: 0;
  }

  .page { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 24px 20px; }

  /* ─── HEADER ─── */
  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }
  .logo-block { display: flex; align-items: center; gap: 14px; }
  .logo-icon {
    width: 42px; height: 42px;
    border: 1.5px solid var(--accent);
    display: flex; align-items: center; justify-content: center;
    clip-path: polygon(12% 0%, 88% 0%, 100% 12%, 100% 88%, 88% 100%, 12% 100%, 0% 88%, 0% 12%);
    background: var(--accent-dim);
    box-shadow: 0 0 16px var(--accent-glow);
  }
  .logo-icon svg { width: 22px; height: 22px; stroke: var(--accent); fill: none; stroke-width: 1.5; }
  .logo-text { font-family: var(--head); font-weight: 700; font-size: 22px; letter-spacing: .12em; color: #fff; }
  .logo-sub { font-family: var(--mono); font-size: 10px; color: var(--text2); letter-spacing: .2em; margin-top: 1px; }

  /* Status */
  .status-cluster { display: flex; align-items: center; gap: 20px; }
  .status-pill {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 14px;
    border: 1px solid var(--border);
    background: var(--panel);
    font-family: var(--mono); font-size: 11px; color: var(--text2);
    letter-spacing: .08em;
  }
  .status-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--text3); flex-shrink: 0; }
  .status-dot.connected { background: var(--green); box-shadow: 0 0 8px var(--green); animation: pulse-green 2s infinite; }
  .status-dot.error { background: var(--red); box-shadow: 0 0 8px var(--red); }
  .status-dot.connecting { background: var(--amber); animation: pulse-amber 1s infinite; }
  @keyframes pulse-green { 0%,100%{opacity:1} 50%{opacity:.4} }
  @keyframes pulse-amber { 0%,100%{opacity:1} 50%{opacity:.3} }

  /* ─── MAIN GRID ─── */
  .main-grid { display: grid; grid-template-columns: 280px 1fr; gap: 20px; }

  /* ─── PANEL BASE ─── */
  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .panel::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: .4;
  }
  .panel-head {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .panel-title {
    font-family: var(--mono); font-size: 11px; letter-spacing: .18em;
    color: var(--accent); text-transform: uppercase;
  }
  .panel-body { padding: 20px; }

  /* ─── LEFT COLUMN ─── */
  .left-col { display: flex; flex-direction: column; gap: 20px; }

  /* ─── DPAD ─── */
  .dpad-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 24px 20px;
  }
  .dpad-row { display: flex; gap: 6px; }

  .dpad-btn {
    width: 68px; height: 68px;
    background: var(--panel2);
    border: 1px solid var(--border2);
    cursor: pointer;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px;
    color: var(--accent);
    font-family: var(--mono); font-size: 9px; letter-spacing: .1em;
    text-transform: uppercase;
    transition: all .1s;
    clip-path: polygon(8% 0%, 92% 0%, 100% 8%, 100% 92%, 92% 100%, 8% 100%, 0% 92%, 0% 8%);
    position: relative;
    -webkit-user-select: none; user-select: none;
  }
  .dpad-btn svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.5; }
  .dpad-btn:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow), inset 0 0 12px rgba(0,200,255,.06);
    color: #fff;
  }
  .dpad-btn:active, .dpad-btn.active {
    background: rgba(0,200,255,.18);
    border-color: var(--accent);
    box-shadow: 0 0 30px var(--accent-glow);
    transform: scale(.95);
  }
  .dpad-center {
    width: 68px; height: 68px;
    background: var(--panel2);
    border: 1px solid var(--border);
    clip-path: polygon(8% 0%, 92% 0%, 100% 8%, 100% 92%, 92% 100%, 8% 100%, 0% 92%, 0% 8%);
    display: flex; align-items: center; justify-content: center;
  }
  .dpad-center svg { width: 28px; height: 28px; stroke: var(--text3); fill: none; }

  /* ─── RECORD + CSV PANEL ─── */
  .action-panel .panel-body { display: flex; flex-direction: column; gap: 12px; }

  .action-btn {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px;
    border: 1px solid var(--border2);
    background: var(--panel2);
    cursor: pointer; width: 100%;
    font-family: var(--head); font-weight: 600; font-size: 14px; letter-spacing: .08em;
    color: var(--text);
    text-transform: uppercase;
    transition: all .15s;
  }
  .action-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

  .rec-indicator {
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--text3); flex-shrink: 0;
    transition: all .2s;
  }
  .rec-indicator.recording {
    background: var(--red);
    box-shadow: 0 0 12px var(--red), 0 0 24px var(--red-dim);
    animation: rec-blink .7s infinite;
  }
  @keyframes rec-blink { 0%,49%{opacity:1} 50%,100%{opacity:.1} }

  .csv-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.5; flex-shrink: 0; }

  .rec-stats {
    font-family: var(--mono); font-size: 10px; color: var(--text2);
    padding: 8px 12px; background: rgba(0,0,0,.3); border: 1px solid var(--border);
    display: flex; justify-content: space-between;
  }
  .rec-stats span { color: var(--accent); }

  /* ─── LOG ─── */
  .log-panel .panel-body { padding: 0; }
  .log-scroll {
    height: 120px; overflow-y: auto;
    padding: 10px 14px;
    font-family: var(--mono); font-size: 10px; line-height: 1.7;
    color: var(--text2);
  }
  .log-scroll::-webkit-scrollbar { width: 3px; }
  .log-scroll::-webkit-scrollbar-track { background: transparent; }
  .log-scroll::-webkit-scrollbar-thumb { background: var(--border2); }
  .log-entry { display: flex; gap: 8px; }
  .log-time { color: var(--text3); flex-shrink: 0; }
  .log-entry.pub .log-msg { color: var(--accent); }
  .log-entry.sub .log-msg { color: var(--green); }
  .log-entry.err .log-msg { color: var(--red); }
  .log-entry.sys .log-msg { color: var(--amber); }

  /* ─── RIGHT COLUMN ─── */
  .right-col {}

  .charts-panel .panel-body { padding: 16px; }
  .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .chart-card {
    background: var(--panel2);
    border: 1px solid var(--border);
    padding: 14px;
    position: relative;
    overflow: hidden;
  }
  .chart-card::after {
    content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 1px;
    background: var(--sensor-color, var(--accent));
    opacity: .5;
  }
  .chart-card-wide { grid-column: 1 / -1; }
  .chart-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 10px; }
  .chart-name {
    font-family: var(--mono); font-size: 10px; letter-spacing: .2em;
    color: var(--text2); text-transform: uppercase;
  }
  .chart-live { display: flex; align-items: center; gap: 8px; }
  .chart-val {
    font-family: var(--mono); font-size: 20px; font-weight: 400;
    color: var(--sensor-color, var(--accent));
    text-shadow: 0 0 12px var(--sensor-color, var(--accent-glow));
    min-width: 60px; text-align: right;
  }
  .chart-unit { font-family: var(--mono); font-size: 10px; color: var(--text3); margin-left: 3px; }
  .chart-canvas-wrap { position: relative; height: 90px; }
  .chart-canvas-wrap.wide { height: 90px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 800px) {
    .main-grid { grid-template-columns: 1fr; }
    .charts-grid { grid-template-columns: 1fr; }
    .chart-card-wide { grid-column: 1; }
  }

  /* Corner decoration */
  .corner-tl { position: absolute; top: 0; left: 0; width: 16px; height: 16px; border-top: 1.5px solid var(--accent); border-left: 1.5px solid var(--accent); opacity: .6; }
  .corner-br { position: absolute; bottom: 0; right: 0; width: 16px; height: 16px; border-bottom: 1.5px solid var(--accent); border-right: 1.5px solid var(--accent); opacity: .6; }

  /* Ticker */
  .ticker {
    font-family: var(--mono); font-size: 10px; color: var(--text3);
    letter-spacing: .1em; padding: 4px 0;
  }

  /* Animate in */
  @keyframes fadeUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
  .panel { animation: fadeUp .4s ease both; }
  .left-col .panel:nth-child(1) { animation-delay: .05s; }
  .left-col .panel:nth-child(2) { animation-delay: .12s; }
  .left-col .panel:nth-child(3) { animation-delay: .18s; }
  .right-col .panel { animation-delay: .1s; }
</style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <header>
    <div class="logo-block">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="14" rx="2"/><circle cx="8" cy="13" r="1.5" fill="currentColor" stroke="none"/><circle cx="16" cy="13" r="1.5" fill="currentColor" stroke="none"/><path d="M8 2v4M16 2v4M9 20h6"/></svg>
      </div>
      <div>
        <div class="logo-text">ROBOT CTRL</div>
        <div class="logo-sub">MQTT DASHBOARD · v2.0</div>
      </div>
    </div>
    <div class="status-cluster">
      <div class="status-pill">
        <span class="status-dot connecting" id="conn-dot"></span>
        <span id="conn-text" style="font-size:10px">INIT...</span>
      </div>
      <div class="status-pill" style="font-size:10px; color: var(--text3)" id="clock">--:--:--</div>
    </div>
  </header>

  <div class="main-grid">

    <!-- LEFT: Controls + Actions + Log -->
    <div class="left-col">

      <!-- D-PAD -->
      <div class="panel">
        <div class="corner-tl"></div>
        <div class="corner-br"></div>
        <div class="panel-head">
          <div class="panel-title">// MOVIMIENTO</div>
        </div>
        <div class="dpad-wrap">
          <div class="dpad-row">
            <button class="dpad-btn" id="btn-adelante" data-cmd="adelante" title="Adelante">
              <svg viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
              FWD
            </button>
          </div>
          <div class="dpad-row">
            <button class="dpad-btn" id="btn-izquierda" data-cmd="izquierda" title="Izquierda">
              <svg viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
              IZQ
            </button>
            <div class="dpad-center">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="7" stroke-dasharray="3 4"/></svg>
            </div>
            <button class="dpad-btn" id="btn-derecha" data-cmd="derecha" title="Derecha">
              <svg viewBox="0 0 24 24"><path d="M5 12h14M12 19l7-7-7-7"/></svg>
              DER
            </button>
          </div>
          <div class="dpad-row">
            <button class="dpad-btn" id="btn-atras" data-cmd="atras" title="Atrás">
              <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              REV
            </button>
          </div>
        </div>
      </div>

      <!-- ACTIONS -->
      <div class="panel action-panel">
        <div class="corner-tl"></div>
        <div class="panel-head">
          <div class="panel-title">// GRABACIÓN</div>
        </div>
        <div class="panel-body">
          <button class="action-btn" id="rec-btn">
            <span class="rec-indicator" id="rec-dot"></span>
            <span id="rec-label">INICIAR GRABACIÓN</span>
          </button>
          <button class="action-btn csv-btn" id="csv-btn">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            EXPORTAR CSV
          </button>
          <div class="rec-stats">
            <span>MUESTRAS: <span id="sample-count">0</span></span>
            <span>DURACIÓN: <span id="rec-duration">00:00</span></span>
          </div>
        </div>
      </div>

      <!-- LOG -->
      <div class="panel log-panel">
        <div class="panel-head">
          <div class="panel-title">// CONSOLA</div>
        </div>
        <div class="log-scroll" id="log"></div>
      </div>

    </div>

    <!-- RIGHT: Sensor Charts -->
    <div class="right-col">
      <div class="panel charts-panel">
        <div class="corner-tl"></div>
        <div class="corner-br"></div>
        <div class="panel-head">
          <div class="panel-title">// SENSORES · TIEMPO REAL</div>
          <div class="ticker" id="ticker" style="margin-left:auto">AGUARDANDO DATOS...</div>
        </div>
        <div class="panel-body">
          <div class="charts-grid" id="charts-grid">

            <div class="chart-card" style="--sensor-color:#00c8ff">
              <div class="chart-header">
                <span class="chart-name">LUZ</span>
                <div class="chart-live">
                  <span class="chart-val" id="val-luz">---</span>
                  <span class="chart-unit">lux</span>
                </div>
              </div>
              <div class="chart-canvas-wrap"><canvas id="c-luz" role="img" aria-label="Sensor luz en tiempo real">Sensor luz</canvas></div>
            </div>

            <div class="chart-card" style="--sensor-color:#ffb830">
              <div class="chart-header">
                <span class="chart-name">SONIDO</span>
                <div class="chart-live">
                  <span class="chart-val" id="val-sonido">---</span>
                  <span class="chart-unit">dB</span>
                </div>
              </div>
              <div class="chart-canvas-wrap"><canvas id="c-sonido" role="img" aria-label="Sensor sonido en tiempo real">Sensor sonido</canvas></div>
            </div>

            <div class="chart-card" style="--sensor-color:#ff3c5a">
              <div class="chart-header">
                <span class="chart-name">TEMPERATURA</span>
                <div class="chart-live">
                  <span class="chart-val" id="val-temp">---</span>
                  <span class="chart-unit">°C</span>
                </div>
              </div>
              <div class="chart-canvas-wrap"><canvas id="c-temp" role="img" aria-label="Sensor temperatura en tiempo real">Sensor temperatura</canvas></div>
            </div>

            <div class="chart-card" style="--sensor-color:#00ff9d">
              <div class="chart-header">
                <span class="chart-name">HUMEDAD</span>
                <div class="chart-live">
                  <span class="chart-val" id="val-hum">---</span>
                  <span class="chart-unit">%</span>
                </div>
              </div>
              <div class="chart-canvas-wrap"><canvas id="c-hum" role="img" aria-label="Sensor humedad en tiempo real">Sensor humedad</canvas></div>
            </div>

            <div class="chart-card chart-card-wide" style="--sensor-color:#b060ff">
              <div class="chart-header">
                <span class="chart-name">DISTANCIA</span>
                <div class="chart-live">
                  <span class="chart-val" id="val-dist">---</span>
                  <span class="chart-unit">cm</span>
                </div>
              </div>
              <div class="chart-canvas-wrap wide"><canvas id="c-dist" role="img" aria-label="Sensor distancia en tiempo real">Sensor distancia</canvas></div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const BROKER = 'wss://broker.hivemq.com/mqtt';
const PORT = 8884;
const MAX_PTS = 60;

const sensors = [
  { key: 'luz',         topic: 'sensores/luz',         canvasId: 'c-luz',    valId: 'val-luz',    color: '#00c8ff', unit: 'lux' },
  { key: 'sonido',      topic: 'sensores/sonido',      canvasId: 'c-sonido', valId: 'val-sonido', color: '#ffb830', unit: 'dB'  },
  { key: 'temperatura', topic: 'sensores/temperatura', canvasId: 'c-temp',   valId: 'val-temp',   color: '#ff3c5a', unit: '°C'  },
  { key: 'humedad',     topic: 'sensores/humedad',     canvasId: 'c-hum',    valId: 'val-hum',    color: '#00ff9d', unit: '%'   },
  { key: 'distancia',   topic: 'sensores/distancia',   canvasId: 'c-dist',   valId: 'val-dist',   color: '#b060ff', unit: 'cm'  },
];

const chartMap = {};
let client;
let recording = false;
let recordedRows = [];
let recStartTime = null;
let recTimer = null;

// ─── CHARTS ───
function makeChart(canvasId, color) {
  const ctx = document.getElementById(canvasId).getContext('2d');
  return new Chart(ctx, {
    type: 'line',
    data: {
      labels: Array(MAX_PTS).fill(''),
      datasets: [{
        data: Array(MAX_PTS).fill(null),
        borderColor: color,
        borderWidth: 1.5,
        pointRadius: 0,
        fill: true,
        backgroundColor: color + '14',
        tension: 0.35,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: { duration: 150 },
      plugins: { legend: { display: false } },
      scales: {
        x: { display: false },
        y: {
          display: true,
          ticks: { font: { size: 9, family: "'Share Tech Mono', monospace" }, maxTicksLimit: 4, color: '#3a5060' },
          grid: { color: 'rgba(30,46,62,.8)', lineWidth: 1 },
          border: { color: 'transparent' }
        }
      }
    }
  });
}

sensors.forEach(s => { chartMap[s.key] = makeChart(s.canvasId, s.color); });

// ─── LOG ───
function log(msg, type='sys') {
  const box = document.getElementById('log');
  const el = document.createElement('div');
  el.className = 'log-entry ' + type;
  const t = new Date().toLocaleTimeString('es', { hour12: false });
  el.innerHTML = `<span class="log-time">${t}</span><span class="log-msg">${msg}</span>`;
  box.appendChild(el);
  box.scrollTop = box.scrollHeight;
  if (box.children.length > 60) box.removeChild(box.firstChild);
}

// ─── STATUS ───
function setStatus(state, text) {
  const dot = document.getElementById('conn-dot');
  const txt = document.getElementById('conn-text');
  dot.className = 'status-dot ' + state;
  txt.textContent = text;
}

// ─── PUSH SENSOR ───
function pushSensor(key, value) {
  const s = sensors.find(x => x.key === key);
  if (!s) return;
  const chart = chartMap[key];
  const ds = chart.data.datasets[0];
  ds.data.push(value);
  chart.data.labels.push('');
  if (ds.data.length > MAX_PTS) { ds.data.shift(); chart.data.labels.shift(); }
  chart.update('quiet');
  const el = document.getElementById(s.valId);
  if (el) el.textContent = Number(value).toFixed(1);

  document.getElementById('ticker').textContent = s.topic + ': ' + Number(value).toFixed(2) + ' ' + s.unit;

  if (recording) {
    recordedRows.push({ ts: new Date().toISOString(), sensor: key, topic: s.topic, valor: value, unidad: s.unit });
    document.getElementById('sample-count').textContent = recordedRows.length;
  }
}

// ─── MQTT ───
function connect() {
  setStatus('connecting', 'CONECTANDO...');
  log('Conectando a ' + BROKER + ':' + PORT, 'sys');
  const clientId = 'webRobot_' + Math.random().toString(36).slice(2, 8).toUpperCase();

  client = mqtt.connect(BROKER, { port: PORT, clientId, clean: true, connectTimeout: 8000 });

  client.on('connect', () => {
    setStatus('connected', clientId);
    log('CONEXIÓN ESTABLECIDA · ' + clientId, 'sys');
    sensors.forEach(s => {
      client.subscribe(s.topic, err => {
        if (!err) log('SUSCRITO → ' + s.topic, 'sub');
        else log('ERR suscripción ' + s.topic, 'err');
      });
    });
  });

  client.on('error', err => {
    setStatus('error', 'ERROR');
    log('ERROR: ' + err.message, 'err');
  });

  client.on('close', () => { setStatus('error', 'DESCONECTADO'); log('Conexión cerrada', 'err'); });
  client.on('reconnect', () => { setStatus('connecting', 'RECONECTANDO...'); log('Reconectando...', 'sys'); });

  client.on('message', (topic, payload) => {
    const val = parseFloat(payload.toString());
    if (isNaN(val)) return;
    log(topic + ' → ' + val, 'sub');
    const s = sensors.find(x => x.topic === topic);
    if (s) pushSensor(s.key, val);
  });
}

// ─── PUBLISH ───
function publish(value) {
  if (client && client.connected) {
    client.publish('movimiento', value);
    log('PUB movimiento → ' + value, 'pub');
  } else {
    log('Sin conexión para publicar', 'err');
  }
}

// ─── BUTTONS ───
document.querySelectorAll('.dpad-btn').forEach(btn => {
  btn.addEventListener('mousedown', () => { btn.classList.add('active'); publish(btn.dataset.cmd); });
  btn.addEventListener('mouseup', () => btn.classList.remove('active'));
  btn.addEventListener('mouseleave', () => btn.classList.remove('active'));
  btn.addEventListener('touchstart', e => { e.preventDefault(); btn.classList.add('active'); publish(btn.dataset.cmd); });
  btn.addEventListener('touchend', () => btn.classList.remove('active'));
});

// Keyboard
const keyMap = { ArrowUp:'btn-adelante', ArrowDown:'btn-atras', ArrowLeft:'btn-izquierda', ArrowRight:'btn-derecha', w:'btn-adelante', s:'btn-atras', a:'btn-izquierda', d:'btn-derecha' };
document.addEventListener('keydown', e => {
  const id = keyMap[e.key];
  if (id) { document.getElementById(id).dispatchEvent(new Event('mousedown')); e.preventDefault(); }
});
document.addEventListener('keyup', e => {
  const id = keyMap[e.key];
  if (id) document.getElementById(id).classList.remove('active');
});

// ─── RECORD ───
document.getElementById('rec-btn').addEventListener('click', () => {
  recording = !recording;
  const dot = document.getElementById('rec-dot');
  const label = document.getElementById('rec-label');
  if (recording) {
    dot.classList.add('recording');
    label.textContent = 'DETENER GRABACIÓN';
    recStartTime = Date.now();
    recTimer = setInterval(() => {
      const sec = Math.floor((Date.now() - recStartTime) / 1000);
      const m = String(Math.floor(sec/60)).padStart(2,'0');
      const s = String(sec%60).padStart(2,'0');
      document.getElementById('rec-duration').textContent = m + ':' + s;
    }, 1000);
    log('GRABACIÓN INICIADA', 'sys');
  } else {
    dot.classList.remove('recording');
    label.textContent = 'INICIAR GRABACIÓN';
    clearInterval(recTimer);
    log('GRABACIÓN DETENIDA · ' + recordedRows.length + ' muestras', 'sys');
  }
});

// ─── CSV ───
document.getElementById('csv-btn').addEventListener('click', () => {
  if (recordedRows.length === 0) { log('Sin datos para exportar', 'err'); return; }
  const header = 'timestamp,sensor,topic,valor,unidad\n';
  const rows = recordedRows.map(r => `${r.ts},${r.sensor},${r.topic},${r.valor},${r.unidad}`).join('\n');
  const blob = new Blob([header + rows], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'robot_sensores_' + new Date().toISOString().slice(0,19).replace(/:/g,'-') + '.csv';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
  log('CSV EXPORTADO · ' + recordedRows.length + ' filas', 'sys');
});

// ─── CLOCK ───
setInterval(() => {
  document.getElementById('clock').textContent = new Date().toLocaleTimeString('es', { hour12: false });
}, 1000);

// ─── INIT ───
connect();
</script>
</body>
</html>
